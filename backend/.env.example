SERVER_PORT=8080
JWT_SECRET=change-me-in-production
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=168h
LOG_LEVEL=debug
CORS_ORIGINS=http://localhost:3000

# APP_ENV controls security-sensitive defaults.
# Set to "development" in local dev to omit the Secure flag on cookies.
# In production leave unset or set to "production".
APP_ENV=development

# How often the background goroutine purges expired revoked-token records.
# Accepts any Go duration string: "15m", "1h", "30s".
REVOKED_TOKEN_CLEANUP_INTERVAL=15m

# ── Database ──────────────────────────────────────────────────────────────────

# SQLite (default — zero config, development only)
DB_DRIVER=sqlite
DB_DSN=./dev.db

# PostgreSQL
# DB_DRIVER=postgres
# DB_DSN=host=localhost user=mansooba password=secret dbname=mansooba port=5432 sslmode=disable

# MySQL / MariaDB  (both use the same MySQL GORM driver)
# DB_DRIVER=mysql
# DB_DSN=mansooba:secret@tcp(localhost:3306)/mansooba?charset=utf8mb4&parseTime=True&loc=Local

# ── Connection pool (optional — per-driver defaults apply) ────────────────────
# DB_MAX_OPEN_CONNS=25     # max open connections (0 = unlimited; SQLite always 1)
# DB_MAX_IDLE_CONNS=5      # idle connections kept in pool
# DB_CONN_MAX_LIFETIME=5m  # max connection lifetime (0 = never expire)

# ── Database idle auto-stop (AWS RDS only — no-op locally, spec 010/ADR-030) ──
# Only engages when DB_DRIVER is postgres/postgresql/mysql/mariadb AND
# RDS_AUTOSTOP_ENABLED isn't disabled AND RDS_INSTANCE_IDENTIFIER is set AND
# DB_DSN's hostname is confirmed as that exact RDS instance's endpoint
# (must both end in ".rds.amazonaws.com" and start with "<RDS_INSTANCE_IDENTIFIER>.").
# The local Postgres container above has a DSN host of "localhost" or a
# Docker service name, which can never satisfy that check — so this whole
# feature stays inert for every local setup, even if you set the vars below
# by accident.
# RDS_AUTOSTOP_ENABLED — defaults to "true"; only an explicit "false"/"0"/"no" disables it.
# RDS_INSTANCE_IDENTIFIER — leave unset locally. Required on the AWS demo deployment, and
#   MUST match the leading label of DB_DSN's host (e.g. identifier "mansooba-db" requires
#   a DSN host like "mansooba-db.<random>.<region>.rds.amazonaws.com").
# RDS_IDLE_TIMEOUT — how long the database can sit idle before being stopped. Defaults to "10m".
# RDS_IDLE_CHECK_INTERVAL — how often the idle/pending-start check runs. Defaults to "1m".
# RDS_START_FAILURE_BOUND — consecutive failed start attempts before giving up. Defaults to 3.

# ── Attachment storage (S3-compatible) ─────────────────────────────────────────
# Local dev: LocalStack (started automatically by docker compose up)
#   STORAGE_ENDPOINT=http://localstack:4566        # unset this and the two below for real AWS S3
#   STORAGE_PRESIGN_ENDPOINT=http://localhost:4566  # only needed when STORAGE_ENDPOINT is a
#                                                    # Docker-internal hostname the browser can't
#                                                    # resolve — the URLs it signs must use a host
#                                                    # reachable from wherever the browser runs.
#   STORAGE_ACCESS_KEY_ID=test
#   STORAGE_SECRET_ACCESS_KEY=test
#   STORAGE_USE_PATH_STYLE=true
# STORAGE_BUCKET — bucket name. Defaults to "mansooba-attachments".
# STORAGE_REGION — defaults to "us-east-1"; LocalStack ignores the value but the SDK requires one.
# STORAGE_PRESIGN_TTL — how long download links remain valid. Defaults to "1h".
# In production: leave STORAGE_ENDPOINT, STORAGE_PRESIGN_ENDPOINT, STORAGE_ACCESS_KEY_ID, and
# STORAGE_SECRET_ACCESS_KEY unset — the AWS SDK resolves the real regional S3 endpoint and
# credentials come from the EC2 instance's IAM role, never a static key (see ADR-029).

# ── Email (SMTP) ──────────────────────────────────────────────────────────────
# Local dev: use Mailpit (started automatically by docker compose up)
#   SMTP_HOST=mailpit
#   SMTP_PORT=1025
#   SMTP_FROM=noreply@mansooba.local
# APP_BASE_URL — public-facing URL of the frontend used to build magic links in password-reset emails.
# Set to the URL users see in their browser (no trailing slash). Leave unset to send raw token only.
#   APP_BASE_URL=http://localhost:3000
# Mailpit web inbox: http://localhost:8025

# ── Spin up a local test database ─────────────────────────────────────────────
# PostgreSQL:
#   docker run --rm -p 5432:5432 -e POSTGRES_USER=mansooba -e POSTGRES_PASSWORD=secret -e POSTGRES_DB=mansooba postgres:17-alpine
# MySQL:
#   docker run --rm -p 3306:3306 -e MYSQL_USER=mansooba -e MYSQL_PASSWORD=secret -e MYSQL_DATABASE=mansooba -e MYSQL_ROOT_PASSWORD=root mysql:8
# MariaDB:
#   docker run --rm -p 3306:3306 -e MARIADB_USER=mansooba -e MARIADB_PASSWORD=secret -e MARIADB_DATABASE=mansooba -e MARIADB_ROOT_PASSWORD=root mariadb:11
