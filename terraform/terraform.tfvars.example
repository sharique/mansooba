# Copy this file to terraform.tfvars and fill in your real values.
# terraform.tfvars is gitignored — never commit it.

aws_region     = "us-east-1"
ssh_public_key = "ssh-ed25519 AAAA... your-key-comment"   # cat ~/.ssh/mansooba.pub
db_password    = "change-me-strong-password"               # also store in SSM /mansooba/DB_PASSWORD
smtp_from      = "noreply@yourdomain.com"                  # verified SES sender; AWS emails you a verification link

# Optional: restrict SSH to your IP only (recommended)
# allowed_ssh_cidr = "1.2.3.4/32"   # replace with: curl ifconfig.me
